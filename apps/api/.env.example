# ローカル(Node + docker Postgres)
DATABASE_URL="postgresql://app:app@localhost:5435/functest_hono?schema=public"
JWT_SECRET="dev-secret-change-me-0000000000000000"

# DB_DRIVER:
#   未設定 or "node" → node-postgres(TCP) で docker Postgres に接続（ローカル）
#   "neon"          → @neondatabase/serverless(HTTP) で Neon に接続（Workers/本番）
# Workers では wrangler.toml の [vars] と secret で投入する。

# --- AI ルーティング（dev = ローカル Ollama / cloud = OpenCode Go）---
# OLLAMA_URL="http://localhost:11434"
# 段1ルータ: "classifier"(埋め込み分類器) / それ以外=rule-base（既定）
# AI_ROUTER="rule"
# 埋め込みモデル（分類器・成果物 build:model 用）。本番化候補は bge-m3。
# OLLAMA_EMBED_MODEL="bge-m3"
# edge SLM の生成モデル。eval:quality の結果 llama3.2:1b は一般知識質問でも回答不可、
# gemma3:4b で実用域（充足不足 100%→37.5%）。dev 既定として gemma3:4b 推奨（要 ollama pull）。
OLLAMA_GEN_MODEL="gemma3:4b"
# cloud LLM(escalation)・LLM-as-Judge 用。
# OPENCODE_API_KEY="..."
